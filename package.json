{
  "name": "qa-agent-skill",
  "version": "0.2.6",
  "type": "module",
  "description": "CLI-first local QA Agent with Codex, Cursor, and other host Skill integrations",
  "bin": {
    "qa-agent": "bin/qa-agent.mjs"
  },
  "files": [
    "bin/",
    "dist/",
    "src/",
    "skill/",
    "README.md",
    "README.en.md",
    "package.json",
    "package-lock.json"
  ],
  "scripts": {
    "build": "npm run clean && node node_modules/typescript/bin/tsc -p tsconfig.build.json",
    "qa-agent": "node --experimental-strip-types src/cli.ts",
    "cli": "node --experimental-strip-types src/cli.ts",
    "test": "node --experimental-strip-types --test tests/*.test.ts",
    "validate": "npm run cli -- skill validate",
    "pack:check": "npm run verify && npm pack --dry-run",
    "typecheck": "node node_modules/typescript/bin/tsc -p tsconfig.typecheck.json",
    "verify": "npm run typecheck && npm test && npm run build",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lengsukq/QA-Agent.git"
  },
  "bugs": {
    "url": "https://github.com/lengsukq/QA-Agent/issues"
  },
  "homepage": "https://github.com/lengsukq/QA-Agent#readme",
  "keywords": [
    "qa",
    "testing",
    "agent",
    "skills",
    "cli",
    "regression"
  ],
  "engines": {
    "node": ">=22.6"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "typescript": "^5.9.3"
  }
}
