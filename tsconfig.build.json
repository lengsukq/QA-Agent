{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",
    "rewriteRelativeImportExtensions": true,
    "declaration": false,
    "sourceMap": false,
    "strict": false,
    "noCheck": false,
    "skipLibCheck": true
  },
  "include": [
    "src/**/*.ts"
  ]
}
